@@ -0,0 +1,28 @@
+// Remote entry — exposed via ModuleFederationPlugin as './entry'.
+// The host shell imports this and passes it to MFBridgeLazy as `register`.
+import { createMFEntry } from '@mf-toolkit/mf-bridge/entry';
+import Cart from './Cart';
+import { setCheckoutEmit, dispatchCommand } from './bridge';
+
+export const register = createMFEntry(
+  Cart,
+  // onBeforeMount — wire emit and subscribe to commands from the host
+  ({ emit, onCommand }) => {
+    setCheckoutEmit(emit);
+
+    onCommand((type, payload) => {
+      if (type === 'addItem') {
+        dispatchCommand({
+          type: 'addItem',
+          payload: payload as { id: string; name: string; price: number },
+        });
+      } else if (type === 'clearCart') {
+        dispatchCommand({ type: 'clearCart' });
+      }
+    });
+  },
+  // onBeforeUnmount — detach emit to avoid stale closures
+  () => {
+    setCheckoutEmit(null);
+  },
+);
