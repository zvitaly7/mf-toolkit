@@ -0,0 +1,28 @@
+import type { CheckoutEvents, CartCommand } from './types';
+
+// ── Emit (checkout → host) ─────────────────────────────────────────────────
+
+let _emit: ((type: string, payload?: unknown) => void) | null = null;
+
+export function setCheckoutEmit(fn: ((type: string, payload?: unknown) => void) | null): void {
+  _emit = fn;
+}
+
+export function checkoutEmit<K extends keyof CheckoutEvents>(
+  type: K,
+  payload: CheckoutEvents[K],
+): void {
+  _emit?.(type, payload);
+}
+
+// ── Command dispatch (host → Cart component) ───────────────────────────────
+
+let _commandHandler: ((cmd: CartCommand) => void) | null = null;
+
+export function setCommandHandler(fn: ((cmd: CartCommand) => void) | null): void {
+  _commandHandler = fn;
+}
+
+export function dispatchCommand(cmd: CartCommand): void {
+  _commandHandler?.(cmd);
+}
diff --git a/scenarios/5-mf-bridge/apps/checkout/src/entry.ts b/scenarios/5-mf-bridge/apps/checkout/src/entry.ts
