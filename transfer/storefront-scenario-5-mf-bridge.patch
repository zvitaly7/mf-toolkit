@@ -0,0 +1,18 @@
+import { create } from 'zustand';
+
+interface User {
+  id: string;
+  name: string;
+}
+
+interface AuthState {
+  user: User | null;
+  login: (user: User) => void;
+  logout: () => void;
+}
+
