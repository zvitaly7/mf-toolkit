+// Remote entry — exposed via ModuleFederationPlugin as './entry'.
+// The host shell imports this and passes it to MFBridgeLazy as `register`.
+import { createMFEntry } from '@mf-toolkit/mf-bridge/entry';
+import ProductList from './ProductList';
+import { setEmit } from './bridge';
+
+export const register = createMFEntry(
+  ProductList,
+  // onBeforeMount — wire emit so ProductList can push events to the host
+  ({ emit }) => {
+    setEmit(emit);
+  },
+  // onBeforeUnmount — detach emit to avoid stale closures
+  () => {
+    setEmit(null);
+  },
+);
