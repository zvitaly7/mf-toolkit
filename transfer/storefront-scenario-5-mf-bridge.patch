@@ -0,0 +1,200 @@
+import React, { useRef, useState, useCallback } from 'react';
+import { MFBridgeLazy, type TypedOnEvent } from '@mf-toolkit/mf-bridge';
+import { useAuthStore } from './store/authStore';
+
+// ── Event contracts (shared with remotes via a types package in production) ──
+
+type CatalogEvents = {
+  productSelected: { id: string; name: string; price: number };
+};
+
+type CheckoutEvents = {
+  orderPlaced: { items: Array<{ id: string; name: string; price: number; quantity: number }>; total: number };
+};
+
+// ── Loader refs — defined at module scope so references are stable ──────────
+// MFBridgeLazy uses the function reference as a cache key: a new function
+// reference on every render would trigger a reload. Module scope guarantees
+// a single reference for the entire session.
+
+const loadCatalog = () => import('catalog/entry').then((m) => m.register);
+const loadCheckout = () => import('checkout/entry').then((m) => m.register);
+
+// ── App ──────────────────────────────────────────────────────────────────────
+
+export default function App() {
+  const { user, login, logout } = useAuthStore();
+
+  // commandRef lets the shell send imperative commands to the checkout remote.
+  // Cart.tsx receives them via onCommand inside entry.ts.
+  const checkoutCommandRef = useRef<((type: string, payload?: unknown) => void) | null>(null);
+
+  const [toast, setToast] = useState<{ message: string; color: string } | null>(null);
+
+  function showToast(message: string, color = '#1976d2') {
+    setToast({ message, color });
+    setTimeout(() => setToast(null), 3500);
+  }
+
+  // catalog → shell: product selected → forward to checkout as addItem command
+  const onCatalogEvent = useCallback<TypedOnEvent<CatalogEvents>>((type, payload) => {
+    if (type === 'productSelected') {
+      checkoutCommandRef.current?.('addItem', payload);
+      showToast(`Added "${payload.name}" to cart`);
+    }
+  }, []);
+
+  // checkout → shell: order placed → show success notification
+  const onCheckoutEvent = useCallback<TypedOnEvent<CheckoutEvents>>((type, payload) => {
+    if (type === 'orderPlaced') {
+      const total = `$${(payload.total / 100).toFixed(2)}`;
+      showToast(`Order placed — ${payload.items.length} items, ${total}`, '#4caf50');
+    }
+  }, []);
+
+  // Shell sends clearCart command to checkout remote
+  function handleClearCart() {
+    checkoutCommandRef.current?.('clearCart');
+  }
+
+  return (
+    <div style={{ minHeight: '100vh', display: 'flex', flexDirection: 'column' }}>
+      {/* ── Nav ─────────────────────────────────────────────────────────── */}
+      <nav
+        style={{
+          padding: '0.75rem 1.5rem',
+          borderBottom: '2px solid #1976d2',
+          display: 'flex',
+          alignItems: 'center',
+          gap: '1.5rem',
+          background: '#fff',
+        }}
+      >
+        <strong style={{ fontSize: '1.1rem', color: '#1976d2' }}>MF Storefront</strong>
+        <span style={{ fontSize: '0.8em', color: '#888', fontFamily: 'monospace' }}>
+          ← powered by @mf-toolkit/mf-bridge
+        </span>
+        <span style={{ marginLeft: 'auto' }}>
+          {user ? (
+            <>
+              {user.name}&nbsp;
+              <button onClick={logout}>Logout</button>
+            </>
+          ) : (
+            <button onClick={() => login({ id: '1', name: 'Demo User' })}>Login</button>
+          )}
+        </span>
+      </nav>
+
+      {/* ── Toast ───────────────────────────────────────────────────────── */}
+      {toast && (
+        <div
+          style={{
+            background: toast.color,
+            color: '#fff',
+            padding: '0.6rem 1.5rem',
+            fontWeight: 500,
+            fontSize: '0.9em',
+            transition: 'opacity 0.3s',
+          }}
+        >
+          {toast.message}
+        </div>
+      )}
+
+      {/* ── Main — side-by-side layout shows event→command round-trip ────── */}
+      <main
+        style={{
+          flex: 1,
+          display: 'grid',
+          gridTemplateColumns: '1fr 1fr',
+          gap: 0,
+          alignItems: 'start',
+        }}
+      >
+        {/* Catalog remote */}
+        <section style={{ padding: '1.25rem', borderRight: '1px solid #eee' }}>
+          <MFBridgeLazy
+            register={loadCatalog}
+            props={{}}
+            fallback={<CatalogSkeleton />}
+            errorFallback={<SlotError label="Catalog" />}
+            onError={(err, retry) => {
+              console.error('[catalog] load failed', err);
+              setTimeout(retry, 2000);
+            }}
+            retryCount={2}
+            retryDelay={500}
+            timeout={5000}
+            onEvent={onCatalogEvent}
+            debug={process.env.NODE_ENV !== 'production'}
+          />
+        </section>
+
+        {/* Checkout remote */}
+        <section style={{ padding: '1.25rem' }}>
+          <MFBridgeLazy
+            register={loadCheckout}
+            props={{}}
+            fallback={<CartSkeleton />}
+            errorFallback={<SlotError label="Cart" />}
+            onError={(err, retry) => {
+              console.error('[checkout] load failed', err);
+              setTimeout(retry, 2000);
+            }}
+            retryCount={2}
+            retryDelay={500}
+            timeout={5000}
+            onEvent={onCheckoutEvent}
+            commandRef={checkoutCommandRef}
+            debug={process.env.NODE_ENV !== 'production'}
+          />
+          <button
+            onClick={handleClearCart}
+            style={{
+              marginTop: '0.75rem',
+              padding: '0.3rem 0.9rem',
+              background: '#f5f5f5',
+              border: '1px solid #ccc',
+              borderRadius: 4,
+              cursor: 'pointer',
+              fontSize: '0.85em',
+            }}
+          >
+            Clear Cart
+          </button>
+        </section>
+      </main>
+    </div>
+  );
+}
+
+// ── Skeletons & error slot ───────────────────────────────────────────────────
+
+function CatalogSkeleton() {
+  return (
+    <div>
+      <div style={{ height: 24, width: 140, background: '#eee', marginBottom: '1rem', borderRadius: 4 }} />
+      {[1, 2, 3, 4, 5, 6].map((i) => (
+        <div key={i} style={{ height: 36, background: '#f5f5f5', marginBottom: 8, borderRadius: 4 }} />
+      ))}
+    </div>
+  );
+}
+
+function CartSkeleton() {
+  return (
+    <div>
+      <div style={{ height: 24, width: 60, background: '#eee', marginBottom: '1rem', borderRadius: 4 }} />
+      <div style={{ height: 80, background: '#f5f5f5', borderRadius: 4 }} />
+    </div>
+  );
+}
+
+function SlotError({ label }: { label: string }) {
+  return (
+    <p style={{ color: '#c62828' }}>
+      {label} is temporarily unavailable. Retrying…
+    </p>
+  );
+}
