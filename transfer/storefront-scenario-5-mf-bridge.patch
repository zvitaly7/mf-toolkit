@@ -0,0 +1,16 @@
+import type { CatalogEvents } from './types';
+
+// Module-level emit ref set by entry.ts and called by ProductList.
+// Avoids circular deps between entry.ts → ProductList → entry.ts.
+let _emit: ((type: string, payload?: unknown) => void) | null = null;
+
+export function setEmit(fn: ((type: string, payload?: unknown) => void) | null): void {
+  _emit = fn;
+}
+
+export function catalogEmit<K extends keyof CatalogEvents>(
+  type: K,
+  payload: CatalogEvents[K],
+): void {
+  _emit?.(type, payload);
+}
