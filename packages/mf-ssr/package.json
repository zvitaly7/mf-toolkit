{
  "name": "@mf-toolkit/mf-ssr",
  "version": "0.2.0",
  "description": "Server-side rendering for microfrontends — edge-native streaming fragment composition for polyrepo Module Federation.",
  "author": "Vitaly Zheltko",
  "license": "MIT",
  "homepage": "https://github.com/zvitaly7/mf-toolkit/tree/main/packages/mf-ssr",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./fragment": {
      "types": "./dist/react-fragment.d.ts",
      "default": "./dist/react-fragment.js"
    },
    "./hydrate": {
      "types": "./dist/hydrate.d.ts",
      "default": "./dist/hydrate.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "microfrontend",
    "module-federation",
    "ssr",
    "streaming",
    "edge",
    "react-server-components",
    "fragment-composition",
    "polyrepo"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/zvitaly7/mf-toolkit",
    "directory": "packages/mf-ssr"
  },
  "peerDependencies": {
    "react": "^18 || ^19 || ^20",
    "react-dom": "^18 || ^19 || ^20"
  },
  "devDependencies": {
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@types/node": "^25.4.0",
    "jsdom": "^26.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.9.3"
  }
}
