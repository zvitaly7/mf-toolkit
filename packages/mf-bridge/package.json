{
  "name": "@mf-toolkit/mf-bridge",
  "version": "1.0.0",
  "description": "Mount microfrontend components from any Module Federation remote — lazy loading, prop streaming, bidirectional events, CSS isolation via Shadow DOM, framework-agnostic remote support, and SSR hydration bridge.",
  "author": "Vitaly Zheltko",
  "license": "MIT",
  "homepage": "https://github.com/zvitaly7/mf-toolkit/tree/main/packages/mf-bridge",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./entry": {
      "types": "./dist/entry.d.ts",
      "default": "./dist/entry.js"
    },
    "./define-entry": {
      "types": "./dist/define-entry.d.ts",
      "default": "./dist/define-entry.js"
    },
    "./hydrate": {
      "types": "./dist/hydrate.d.ts",
      "default": "./dist/hydrate.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "bench": "vitest bench --run",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "microfrontend",
    "module-federation",
    "react",
    "vue",
    "angular",
    "svelte",
    "bridge",
    "prop-streaming",
    "lazy-loading",
    "shadow-dom",
    "css-isolation",
    "ssr-hydration"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/zvitaly7/mf-toolkit",
    "directory": "packages/mf-bridge"
  },
  "peerDependencies": {
    "react": "^18 || ^19 || ^20",
    "react-dom": "^18 || ^19 || ^20"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@types/node": "^25.4.0",
    "jsdom": "^26.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.9.3"
  }
}
