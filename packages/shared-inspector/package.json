{
  "name": "@mf-toolkit/shared-inspector",
  "version": "0.5.0",
  "description": "Stop debugging Module Federation in production. Audit shared config at build time.",
  "author": "Vitaly Zheltko",
  "license": "MIT",
  "type": "module",
  "bin": {
    "mf-inspector": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./webpack": {
      "types": "./dist/plugins/webpack.d.ts",
      "default": "./dist/plugins/webpack.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "microfrontend",
    "module-federation",
    "shared",
    "webpack",
    "analyzer"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/zvitaly7/mf-toolkit",
    "directory": "packages/shared-inspector"
  },
  "dependencies": {
    "semver": "^7.6.0"
  },
  "peerDependencies": {
    "typescript": ">=4.7"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/semver": "^7.5.8",
    "@types/node": "^25.4.0",
    "typescript": "^5.9.3"
  }
}
