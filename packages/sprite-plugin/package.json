{
  "name": "@mf-toolkit/sprite-plugin",
  "version": "0.1.0",
  "description": "SVG sprite generator that statically analyzes your code and builds optimized sprites containing only the icons your microfrontend actually uses.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./webpack": {
      "types": "./dist/plugins/webpack.d.ts",
      "default": "./dist/plugins/webpack.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "microfrontend",
    "svg",
    "sprite",
    "webpack",
    "icons",
    "optimization"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/zvitaly7/mf-toolkit",
    "directory": "packages/sprite-plugin"
  },
  "dependencies": {
    "svgo": "^4.0.1"
  }
}
